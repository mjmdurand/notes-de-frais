# Base de données PostgreSQL
POSTGRES_USER=ndf
POSTGRES_PASSWORD=ndfpassword
POSTGRES_DB=ndf_db

# MinIO (stockage des justificatifs)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_BUCKET_NAME=ndf-documents
# URL publique MinIO (optionnel) — utile si MinIO est exposé via un reverse-proxy/CDN
# Exemple : https://ged.mondomaine.fr
MINIO_PUBLIC_BASE_URL=

# JWT
JWT_SECRET=change-me-in-production-secret-key

# ── Email ────────────────────────────────────────────────────────────────────
# Mode : plain | starttls | oauth2
#
# SMTP non authentifié — relais O365 (connecteur Exchange entrant requis)
#   SMTP_MODE=plain
#   SMTP_HOST=<domaine>.mail.protection.outlook.com
#   SMTP_PORT=25
#
# SMTP authentifié — O365 standard (recommandé)
#   SMTP_MODE=starttls
#   SMTP_HOST=smtp.office365.com
#   SMTP_PORT=587
#   SMTP_USER=ndf@mondomaine.com
#   SMTP_PASSWORD=motdepasse
#
# OAuth2 Microsoft Graph — Exchange Online (usage futur)
#   SMTP_MODE=oauth2
#   SMTP_OAUTH_TENANT_ID=...
#   SMTP_OAUTH_CLIENT_ID=...
#   SMTP_OAUTH_CLIENT_SECRET=...
# ─────────────────────────────────────────────────────────────────────────────
SMTP_MODE=starttls
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_FROM=ndf@mondomaine.com
SMTP_USER=ndf@mondomaine.com
SMTP_PASSWORD=

# OAuth2 Exchange Online / Microsoft 365 (usage futur)
# App Azure AD avec permission Mail.Send (application, non déléguée) + consentement admin
SMTP_OAUTH_TENANT_ID=
SMTP_OAUTH_CLIENT_ID=
SMTP_OAUTH_CLIENT_SECRET=

# URL du frontend (utilisée dans les liens des emails)
FRONTEND_URL=http://localhost:3000

# Comptes de démonstration (mettre false en production)
DEMO_ACCOUNTS=true

# Compte administrateur initial (créé automatiquement au premier démarrage)
ADMIN_EMAIL=admin@company.com
ADMIN_PASSWORD=Admin1234!
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=Système
